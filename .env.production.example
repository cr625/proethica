# ProEthica Production Environment Variables
# Copy this file to .env on the production server and fill in actual values.

# Flask
FLASK_ENV=production
SECRET_KEY=<generate-a-strong-random-key>
ENVIRONMENT=production
DEBUG=False

# Database
SQLALCHEMY_DATABASE_URI=postgresql://proethica_user:<password>@localhost:5432/ai_ethical_dm

# LLM API Keys
ANTHROPIC_API_KEY=<your-anthropic-api-key>
OPENAI_API_KEY=<your-openai-api-key>

# Model Selection
CLAUDE_DEFAULT_MODEL=claude-sonnet-4-6
CLAUDE_FAST_MODEL=claude-haiku-4-5-20251001
CLAUDE_POWERFUL_MODEL=claude-opus-4-6

# Embeddings
EMBEDDING_PROVIDER_PRIORITY=local,openai,anthropic,google
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# OntServe Integration
ONTSERVE_MCP_URL=http://localhost:8082
ONTSERVE_WEB_URL=https://ontserve.ontorealm.net
EXTERNAL_MCP_URL=http://localhost:8082
ONTSERVE_TIMEOUT=30

# Feature Flags
ENABLE_MCP_ONTOLOGY_ACCESS=true
ENABLE_EXTERNAL_MCP_ACCESS=true
ENABLE_ONTOLOGY_DRIVEN_LANGEXTRACT=true
PROVENANCE_ENVIRONMENT=production

# Monitoring & Alerting
ALERT_EMAIL_ENABLED=true
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=<your-email>
ALERT_SMTP_PASS=<your-app-password>
ALERT_EMAIL_FROM=<your-email>
ALERT_EMAIL_TO=<alert-recipient>
ALERT_RATE_LIMIT=300
