# ProEthica Development Environment Variables
# Copy this file to .env and fill in your API keys.

# Flask
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=dev-secret-change-in-production
ENVIRONMENT=development

# Database
SQLALCHEMY_DATABASE_URI=postgresql://postgres:PASS@localhost:5432/ai_ethical_dm

# LLM API Keys (at minimum, set ANTHROPIC_API_KEY)
ANTHROPIC_API_KEY=<your-anthropic-api-key>
OPENAI_API_KEY=<your-openai-api-key>
# GOOGLE_API_KEY=<your-google-api-key>
# GOOGLE_GEMINI_API_KEY=<your-gemini-api-key>

# Model Selection
CLAUDE_DEFAULT_MODEL=claude-sonnet-4-6
CLAUDE_FAST_MODEL=claude-haiku-4-5-20251001
CLAUDE_POWERFUL_MODEL=claude-opus-4-6

# Embeddings
EMBEDDING_PROVIDER_PRIORITY=local,openai,anthropic,google
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# OntServe Integration (start OntServe MCP before ProEthica)
ONTSERVE_WEB_URL=http://localhost:5003
ONTSERVE_MCP_URL=http://localhost:8082
EXTERNAL_MCP_URL=http://localhost:8082
ONTSERVE_TIMEOUT=30

# Feature Flags
USE_DRAFT_ONTOLOGIES=true
ENABLE_MCP_ONTOLOGY_ACCESS=true
ENABLE_EXTERNAL_MCP_ACCESS=true
ENABLE_ONTOLOGY_DRIVEN_LANGEXTRACT=true
PROVENANCE_ENVIRONMENT=development

# Monitoring (optional)
# ALERT_EMAIL_ENABLED=false
# ALERT_SMTP_HOST=smtp.gmail.com
# ALERT_SMTP_PORT=587
# ALERT_SMTP_USER=
# ALERT_SMTP_PASS=
# ALERT_EMAIL_FROM=
# ALERT_EMAIL_TO=

# Validation study: Prolific completion-code redemption (validation pivot).
# Fixed code registered in the Prolific study config. When set, the /complete
# page shows a "Return to Prolific" button that redirects to
# https://app.prolific.co/submissions/complete?cc=<this value>.
# When unset, the per-session completion_code is shown for manual paste only.
# Populate once the Prolific researcher account and study exist.
# PROLIFIC_COMPLETION_CODE_SUCCESS=
