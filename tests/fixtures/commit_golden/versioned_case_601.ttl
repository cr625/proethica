case601:DP1 a proeth-cases:DecisionPoint,
        owl:NamedIndividual ;
    rdfs:label "DP1" ;
    proeth:boardChosenOption "Clarify" ;
    proeth:boardResolution "The Board found the unclarified use of Diplomate misleading." ;
    proeth:citedProvision "II.1.a",
        "III.3.a" ;
    proeth:decisionPointId "DP1" ;
    proeth:decisionQuestion "Should Engineer A have used the title \"Diplomate\" without clarifying it was not a PE license?" ;
    proeth:focus "Whether Engineer A should have disclosed use of the Diplomate title." ;
    proeth:intensityScore 0.6 ;
    proeth:option "1. Use as-is: Use the Diplomate title without further clarification",
        "2. Clarify: Clarify the Diplomate title is not a PE license" ;
    proeth:qcAlignmentScore 0.75 ;
    proeth:toulminClaim "Engineer A should have clarified the title." ;
    proeth:toulminData "The title Diplomate is a specialty certification, not a PE license." ;
    proeth:toulminQualifier "absent a clear disclaimer" ;
    proeth:toulminRebuttal "Some Diplomates are commonly known by that title alone." ;
    proeth:toulminWarrant "NSPE Code requires accurate representation of qualifications." ;
    prov:wasGeneratedBy "ProEthica Case 601 Extraction" .

case601:Design_Under_Peer_Review_Prior_to_Signing a proeth-core:State,
